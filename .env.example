# 学术推送系统 - 环境变量配置示例
# 复制此文件为 .env 并填入实际值用于本地测试

# ===========================================
# 必需配置
# ===========================================

# 企业微信Webhook URL（从企业微信群机器人获取）
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=your-webhook-key

# ===========================================
# AI服务配置（选择一个）
# ===========================================

# AI服务选择：deepseek, claude, qwen, none
# - deepseek: 使用DeepSeek（推荐，支持国内支付，价格极低）
# - claude: 使用Claude（需要海外信用卡）
# - qwen: 使用通义千问（需要实现对应代码）
# - none: 不使用AI，直接用原始摘要
AI_SERVICE=deepseek

# DeepSeek API密钥（从 https://platform.deepseek.com/ 获取）
# 支持支付宝/微信支付，每月成本不到2毛钱
DEEPSEEK_API_KEY=sk-your-deepseek-key-here

# Claude API密钥（从 https://console.anthropic.com/ 获取）
# 需要海外信用卡，新用户$5免费额度
# CLAUDE_API_KEY=sk-ant-api03-your-api-key-here

# ===========================================
# 可选配置
# ===========================================

# 每日推送论文数量（默认6篇）
PAPERS_TO_SEND=6

# 日志级别（DEBUG, INFO, WARNING, ERROR）
LOG_LEVEL=INFO

# 是否启用arXiv数据源（默认true）
ENABLE_ARXIV=true

# 是否启用Papers with Code（默认false，需要实现对应fetcher）
ENABLE_PAPERSWITHCODE=false

# 是否启用Hugging Face（默认false，需要实现对应fetcher）
ENABLE_HUGGINGFACE=false

# 获取最近N天的论文（默认1天，建议2-3天确保有足够论文）
# 如果定时任务运行时arXiv还未更新，增加此值可以从前几天获取论文
FETCH_DAYS=2

# ===========================================
# 本地测试提示
# ===========================================
#
# 1. 复制此文件：cp .env.example .env
# 2. 填入实际的API密钥和Webhook URL
# 3. 运行测试：python -m src.main
# 4. 查看logs/目录下的日志文件
#
